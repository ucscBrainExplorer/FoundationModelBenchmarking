[Term]
id: CL:0000136
name: adipocyte
alt_id: CL:0000450
def: "A fat-storing cell found mostly in the abdominal cavity and subcutaneous tissue of mammals. Fat is usually stored in the form of triglycerides." [MESH:D017667]
subset: cellxgene_subset
