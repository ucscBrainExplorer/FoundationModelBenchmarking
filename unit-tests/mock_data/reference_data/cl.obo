property_value: foaf:depiction http://purl.obolibrary.org/obo/cl/images/fnins-16-1129414-g001.jpg {dc:license="https://creativecommons.org/licenses/by/4.0/", xref="doi:10.3389/fnins.2022.1129414", comment="α1 tanycytes are the most dorsally located subtype, followed by α2 tanycytes, then β1 tanycytes, and finally β2 tanycytes which occupy the ventricular floor. 3V, third ventricle; Arc, arcuate nucleus; DMH, dorsomedial hypothalamic nucleus; VMH, ventromedial hypothalamic nucleus."}
